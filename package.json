{
  "name": "nftgen",
  "version": "1.0.0",
  "description": "NFT collection generator with improved trait weighting and variation.",
  "main": "main.js",
  "scripts": {
    "generate": "node index.js",
    "preview": "node utils/preview.js",
    "rarity": "node utils/rarity.js",
    "ui": "node server.js",
    "start": "electron .",
    "dist": "electron-builder"
  },
  "license": "MIT",
  "dependencies": {
    "@napi-rs/canvas": "^0.1.95",
    "express": "^4.22.1",
    "sha1": "^1.1.1"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.nftgen.app",
    "productName": "Tojiba NFT Compositor 2",
    "icon": "assets/icon.png",
    "asarUnpack": [
      "node_modules/@napi-rs/**"
    ],
    "files": [
      "main.js",
      "server.js",
      "index.js",
      "src/engine.js",
      "src/groups.json",
      "public/**/*",
      "constants/**/*",
      "utils/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github"
      }
    ],
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.graphics-design"
    }
  }
}
