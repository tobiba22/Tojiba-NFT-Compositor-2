{
  "name": "nftgen",
  "version": "1.0.8",
  "description": "NFT collection generator with improved trait weighting and variation.",
  "author": "Tojiba",
  "main": "main.js",
  "scripts": {
    "generate": "node index.js",
    "preview": "node utils/preview.js",
    "rarity": "node utils/rarity.js",
    "ui": "node server.js",
    "start": "electron .",
    "dist": "electron-builder"
  },
  "license": "MIT",
  "dependencies": {
    "@napi-rs/canvas": "^0.1.95",
    "express": "^4.22.1",
    "sha1": "^1.1.1"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.tojiba.nftcompositor2",
    "productName": "Tojiba NFT Compositor 2",
    "copyright": "Copyright © 2025 Tojiba",
    "icon": "assets/icon",
    "asarUnpack": [
      "node_modules/@napi-rs/**"
    ],
    "files": [
      "main.js",
      "server.js",
      "index.js",
      "src/engine.js",
      "src/groups.json",
      "public/**/*",
      "constants/**/*",
      "utils/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github"
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "zip",  "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Tojiba NFT Compositor 2",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": [
        { "target": "dmg" }
      ],
      "category": "public.app-category.graphics-design"
    },
    "dmg": {
      "window": { "width": 540, "height": 380 }
    }
  }
}
